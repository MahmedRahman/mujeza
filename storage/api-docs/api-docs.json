{
    "openapi": "3.0.0",
    "info": {
        "title": "Mujeza API",
        "description": "API documentation for Mujeza products and related endpoints.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Default API server"
        }
    ],
    "paths": {
        "/api/products": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Get products list",
                "description": "Returns all products in one response.",
                "operationId": "getProducts",
                "responses": {
                    "200": {
                        "description": "Products fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/products/search": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Search products by name",
                "description": "Searches products using product title or description (partial match).",
                "operationId": "searchProductsByName",
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "description": "Product name to search for (optional if search is provided)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "سدر"
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Alias for name query parameter",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "سدر"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Products search completed successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "query": {
                                            "type": "string",
                                            "example": "سدر"
                                        },
                                        "count": {
                                            "type": "integer",
                                            "example": 2
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Products",
            "description": "Products"
        }
    ]
}