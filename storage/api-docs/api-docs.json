{
    "openapi": "3.0.0",
    "info": {
        "title": "Mujeza API",
        "description": "API documentation for Mujeza products and related endpoints.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Default API server"
        }
    ],
    "paths": {
        "/api/products": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Get products list",
                "description": "Returns all products in one response.",
                "operationId": "getProducts",
                "responses": {
                    "200": {
                        "description": "Products fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/products/search": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Search products by name",
                "description": "Searches products using product title or description (partial match).",
                "operationId": "searchProductsByName",
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "description": "Product name to search for (optional if search is provided)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "سدر"
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "description": "Alias for name query parameter",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "سدر"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Products search completed successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "query": {
                                            "type": "string",
                                            "example": "سدر"
                                        },
                                        "count": {
                                            "type": "integer",
                                            "example": 2
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/branches": {
            "get": {
                "tags": [
                    "Branches"
                ],
                "summary": "Get branches list",
                "description": "Returns all branches in one response.",
                "operationId": "getBranches",
                "responses": {
                    "200": {
                        "description": "Branches fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/complaints": {
            "get": {
                "tags": [
                    "Complaints"
                ],
                "summary": "Get complaints and inquiries list",
                "description": "Returns complaints list with optional text search in title, description, or phone.",
                "operationId": "getComplaints",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Search query (optional)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "تأخير الطلب"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Complaints fetched successfully"
                    }
                }
            },
            "post": {
                "tags": [
                    "Complaints"
                ],
                "summary": "Create complaint or inquiry",
                "operationId": "storeComplaint",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "description",
                                    "phone"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "استفسار عن المنتج"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "أريد معرفة طريقة الاستخدام المناسبة."
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "96550000000"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Complaint created successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/complaints/{id}": {
            "get": {
                "tags": [
                    "Complaints"
                ],
                "summary": "Get a single complaint/inquiry",
                "operationId": "showComplaint",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Complaint fetched successfully"
                    }
                }
            },
            "put": {
                "tags": [
                    "Complaints"
                ],
                "summary": "Update complaint or inquiry",
                "operationId": "updateComplaint",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "description",
                                    "phone"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "شكوى عن تأخر الرد"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "لم يصلني رد حتى الآن."
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "96550000000"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Complaint updated successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Complaints"
                ],
                "summary": "Delete complaint or inquiry",
                "operationId": "deleteComplaint",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Complaint deleted successfully"
                    }
                }
            }
        },
        "/api/orders": {
            "post": {
                "tags": [
                    "Orders"
                ],
                "summary": "Create order",
                "description": "Creates a new order. The items field must be a single text value describing requested products.",
                "operationId": "storeOrder",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "customer_name",
                                    "delivery_address",
                                    "items"
                                ],
                                "properties": {
                                    "customer_name": {
                                        "type": "string",
                                        "example": "محمد أحمد"
                                    },
                                    "delivery_address": {
                                        "type": "string",
                                        "example": "الكويت - حولي - شارع بيروت - قطعة 4 - منزل 12"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "96550000000"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "قيد المعالجة"
                                    },
                                    "items": {
                                        "type": "string",
                                        "example": "عسل سدر 2 عبوة + عسل كشميري 1 عبوة"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Order created successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/orders/status": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "Get order status",
                "description": "Returns latest order status and all matching orders by order_number or customer_name or phone.",
                "operationId": "getOrderStatusByPhone",
                "parameters": [
                    {
                        "name": "order_number",
                        "in": "query",
                        "description": "Order number (preferred)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 1024
                        }
                    },
                    {
                        "name": "customer_name",
                        "in": "query",
                        "description": "Customer name",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "محمد أحمد"
                        }
                    },
                    {
                        "name": "phone",
                        "in": "query",
                        "description": "Customer phone number (optional fallback)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "96550000000"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order status fetched successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/whatsapp/auto-reply/numbers": {
            "get": {
                "tags": [
                    "WhatsApp"
                ],
                "summary": "Get chats numbers with auto-reply state",
                "description": "Returns chats list (number/name) and whether auto-reply is allowed per chat, plus global toggle state.",
                "operationId": "whatsappAutoReplyNumbers",
                "responses": {
                    "200": {
                        "description": "Auto-reply numbers list fetched successfully"
                    },
                    "422": {
                        "description": "Evolution API is not configured"
                    }
                }
            }
        },
        "/whatsapp/auto-reply/number-status": {
            "get": {
                "tags": [
                    "WhatsApp"
                ],
                "summary": "Get auto-reply status for single chat/phone",
                "description": "Checks whether auto-reply is allowed for a specific chat_id or phone, considering global + override values.",
                "operationId": "whatsappAutoReplyNumberStatus",
                "parameters": [
                    {
                        "name": "chat_id",
                        "in": "query",
                        "description": "WhatsApp chat JID (optional if phone is provided)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "201011223344@s.whatsapp.net"
                        }
                    },
                    {
                        "name": "phone",
                        "in": "query",
                        "description": "Phone number in local or international format (optional if chat_id is provided)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "201011223344"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Auto-reply status evaluated successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/whatsapp/auto-reply/settings": {
            "get": {
                "tags": [
                    "WhatsApp"
                ],
                "summary": "Get global auto-reply setting",
                "operationId": "whatsappAutoReplySettings",
                "responses": {
                    "200": {
                        "description": "Global auto-reply setting fetched successfully"
                    }
                }
            }
        },
        "/whatsapp/auto-reply/global": {
            "post": {
                "tags": [
                    "WhatsApp"
                ],
                "summary": "Enable or disable global auto-reply",
                "operationId": "whatsappUpdateGlobalAutoReply",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "enabled"
                                ],
                                "properties": {
                                    "enabled": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Global auto-reply updated successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/whatsapp/auto-reply/chat": {
            "post": {
                "tags": [
                    "WhatsApp"
                ],
                "summary": "Enable or disable auto-reply for specific chat",
                "operationId": "whatsappUpdateChatAutoReply",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "chat_id",
                                    "enabled"
                                ],
                                "properties": {
                                    "chat_id": {
                                        "type": "string",
                                        "example": "201011223344@s.whatsapp.net"
                                    },
                                    "enabled": {
                                        "type": "boolean",
                                        "example": false
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Per-chat auto-reply override updated successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Products",
            "description": "Products"
        },
        {
            "name": "Branches",
            "description": "Branches"
        },
        {
            "name": "Complaints",
            "description": "Complaints"
        },
        {
            "name": "Orders",
            "description": "Orders"
        },
        {
            "name": "WhatsApp",
            "description": "WhatsApp"
        }
    ]
}